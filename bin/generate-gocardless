#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

cd "$PROJECT_ROOT"

TEMP_DIR=$(mktemp -d)
trap "rm -rf $TEMP_DIR" EXIT

npx @openapitools/openapi-generator-cli generate \
    -i src/gocardless-client/openapi.yaml \
    -g swift6 \
    -o "src/gocardless-client/" \
    --additional-properties=packageName=GoCardless,enumCaseProperties=false,removeTimestamp=true

echo "GoCardless types generated successfully"